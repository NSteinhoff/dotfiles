command = "/opt/homebrew/bin/bash --login"

cursor-style = block
macos-auto-secure-input = true
shell-integration-features = no-cursor
mouse-hide-while-typing = true

# Font
# font-family = "Iosevka Nerd Font Mono"
font-family  = "VictorMono Nerd Font Mono"
font-size    = 15
font-feature = "-calt, -liga, -dlig"

# === Unicolor
# theme = subliminal
# theme = Onenord

# === Dark / Light
# theme = light:No Clown Fiesta Light,dark:No Clown Fiesta 
# theme = light:Iceberg Light,dark:Iceberg Dark
# theme = light:Zenwritten Light,dark:Ghostty Default Style Dark
# theme = light:Neobones Light,dark:Neobones Dark
# theme = light:Gruvbox Light Hard,dark:Gruvbox Dark
theme = light:gruvbox-light,dark:gruvbox-dark
# theme = light:Rose Pine Dawn,dark:Rose Pine

# Keys
macos-option-as-alt = left
# keybind = global:cmd+grave_accent=toggle_quick_terminal
keybind = super+enter=toggle_split_zoom

quick-terminal-size = 40%

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 5s
