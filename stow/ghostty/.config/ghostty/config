command = "/opt/homebrew/bin/bash --login"

cursor-style = block
macos-auto-secure-input = true
shell-integration-features = no-cursor
mouse-hide-while-typing = true

# Font
# font-family = "Iosevka Nerd Font Mono"
font-family  = "VictorMono Nerd Font Mono"
font-size    = 13
font-feature = "-calt, -liga, -dlig"

# Theme
# theme = light:default-light,dark:default-dark
# theme = light:rose-pine-dawn,dark:rose-pine-moon
# theme = light:Neobones Light,dark:Neobones Dark
# theme = light:Gruvbox Light,dark:Gruvbox Dark
# theme = light:Selenized Light,dark:Selenized Dark

# Keys
macos-option-as-alt = left
# keybind = global:cmd+grave_accent=toggle_quick_terminal
keybind = super+enter=toggle_split_zoom

quick-terminal-size = 40%

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 5s
